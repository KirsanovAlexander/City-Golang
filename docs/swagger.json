    "definitions": {
        "models.AdjustResourcesRequest": {
            "type": "object",
            "properties": {
                "energy": {
                    "type": "integer",
                    "example": 200
                },
                "food": {
                    "type": "integer",
                    "example": 150
                },
                "money": {
                    "type": "integer",
                    "example": 300
                }
            }
        },
        "models.Building": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "health": {
                    "type": "integer",
                    "example": 100
                },
                "id": {
                    "type": "string"
                },
                "level": {
                    "type": "integer"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "models.BuildingEffect": {
            "type": "object",
            "properties": {
                "effect": {
                    "type": "string",
                    "example": "+5 food per level per day"
                },
                "type": {
                    "type": "string",
                    "example": "farm"
                }
            }
        },
        "models.BuildRequest": {
            "type": "object",
            "properties": {
                "type": {
                    "type": "string",
                    "example": "farm",
                    "enum": [
                        "house",
                        "farm",
                        "factory",
                        "powerplant"
                    ]
                }
            }
        },
        "models.ChangeHappinessRequest": {
            "type": "object",
            "properties": {
                "delta": {
                    "type": "number",
                    "example": 5,
                    "minimum": -100,
                    "maximum": 100
                }
            }
        },
        "models.ChangeJobRequest": {
            "type": "object",
            "properties": {
                "job": {
                    "type": "string",
                    "example": "worker",
                    "enum": [
                        "unemployed",
                        "farmer",
                        "worker",
                        "engineer"
                    ]
                }
            }
        },
        "models.Citizen": {
            "type": "object",
            "properties": {
                "createdAt": {
                    "type": "string"
                },
                "happiness": {
                    "type": "number"
                },
                "id": {
                    "type": "string"
                },
                "job": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "models.CitizenCreateRequest": {
            "type": "object",
            "properties": {
                "job": {
                    "type": "string",
                    "example": "farmer",
                    "enum": [
                        "unemployed",
                        "farmer",
                        "worker",
                        "engineer"
                    ]
                },
                "name": {
                    "type": "string",
                    "example": "John Doe"
                }
            }
        },
        "models.City": {
            "type": "object",
            "properties": {
                "buildings": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Building"
                    }
                },
                "citizens": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Citizen"
                    }
                },
                "day": {
                    "type": "integer"
                },
                "resources": {
                    "$ref": "#/definitions/models.Resources"
                },
                "settings": {
                    "$ref": "#/definitions/models.CitySettings"
                }
            }
        },
        "models.CitySettings": {
            "type": "object",
            "properties": {
                "baseFoodUsePerCap": {
                    "type": "integer"
                },
                "difficulty": {
                    "type": "string"
                },
                "energyPerEngineer": {
                    "type": "integer"
                },
                "foodPerFarmer": {
                    "type": "integer"
                },
                "happinessDecay": {
                    "type": "number"
                },
                "moneyPerWorker": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                }
            }
        },
        "models.CreateCityRequest": {
            "type": "object",
